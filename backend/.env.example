# ───────────────────────────── Core ─────────────────────────────
APP_NAME=Convexo
DATABASE_URL=sqlite:///./crm.db
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Origens CORS permitidas (separadas por vírgula, sem espaços).
# Inclui o frontend (5173), o gateway/testes e a PÁGINA DE EXEMPLO DO WIDGET (8080/5174).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost:5174

# ───────────────────────────── WhatsApp (gateway) ─────────────────────────────
GATEWAY_URL=http://localhost:3001
WHATSAPP_WEBHOOK_URL=http://localhost:8000/webhook
WHATSAPP_BOT_NAME=Assistente

# ───────────────────────────── Frontend ─────────────────────────────
FRONTEND_URL=http://localhost:5173

# ───────────────────────────── E-mail (Google Apps Script) ─────────────────────────────
# O envio de e-mail (tickets, reset de senha e formulário do widget) é SEMPRE via
# Google Apps Script: o backend faz POST JSON {to, subject, html, fromName?} para a URL
# abaixo. Se estiverem vazias, o envio é ignorado silenciosamente (apenas log).
EMAIL_GOOGLE_SCRIPT_URL=
EMAIL_GOOGLE_SCRIPT_SECRET=
EMAIL_FROM_NAME=Convexo

# ───────────────────────────── Taky (integração de tarefas) ─────────────────────────────
TAKY_API_URL=
TAKY_EMAIL=
TAKY_PASSWORD=
TAKY_DEFAULT_PROJECT_ID=
TAKY_DEFAULT_USER_ID=

# ───────────────────────────── LLM (Groq — compatível OpenAI) ─────────────────────────────
API_GROQ=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_PRIMARY_MODEL=groq/compound-mini
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_FALLBACK_MODELS=openai/gpt-oss-20b
GROQ_MAX_RETRIES=3
GROQ_TEMPERATURE=0.8

# ───────────────────────────── Uploads / polling ─────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=15
EMAIL_POLL_SECONDS=60

# ───────────────────────────── Widget de chat do site ─────────────────────────────
# O widget NÃO usa variáveis de ambiente. Suas chaves ficam no BANCO DE DADOS,
# na tabela widget_configs, criadas pelo admin:
#   - api_token  -> usado no front como ?token= (ou atributo data-token)
#   - whatsapp_number -> número que o botão WhatsApp abre via wa.me
#   - contact_email   -> destino do formulário de e-mail do widget
# Crie/gere via POST /widget/config (admin) e edite via PUT /widget/config/{id}.
# A origem do site cliente deve estar em ALLOWED_ORIGINS acima (ex.: 8080/5174).
