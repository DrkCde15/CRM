APP_NAME=CRM
DATABASE_URL=sqlite:///./crm.db
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

GATEWAY_URL=http://localhost:3001
WHATSAPP_WEBHOOK_URL=http://localhost:8000/webhook
FRONTEND_URL=http://localhost:5173

# E-mail — sempre via Google Apps Script (web app deployado que envia o e-mail)
EMAIL_GOOGLE_SCRIPT_URL=
EMAIL_GOOGLE_SCRIPT_SECRET=
EMAIL_FROM_NAME=CRM AutoAssist

# LLM (Groq — endpoint compatível com OpenAI)
API_GROQ=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_PRIMARY_MODEL=groq/compound-mini
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_FALLBACK_MODELS=openai/gpt-oss-20b
GROQ_MAX_RETRIES=3
GROQ_TEMPERATURE=0.8
